# Research OS — local environment variables
# Copy to `.env.local` and fill in values. Never commit `.env.local`.
#
# Cursor Cloud: add the same keys in the environment Secrets tab
# (https://cursor.com/dashboard/cloud-agents) instead of committing files.
# Browser app: paste the key in Login / Settings (stored in localStorage only).

# Required for OpenRouter LLM calls (get a key at https://openrouter.ai/keys)
OPENROUTER_API_KEY=

# Optional — default model id when tooling/scripts need one
# OPENROUTER_MODEL=anthropic/claude-sonnet-4
