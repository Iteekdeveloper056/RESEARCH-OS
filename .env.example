# Copy this file to .env and fill in your own values. Never commit the real .env file.

# Required: your OpenRouter API key (https://openrouter.ai/keys).
# Gives Research-OS access to 300+ models (OpenAI, Anthropic, Google, Meta,
# Mistral, DeepSeek, xAI, and more) through a single key.
OPENROUTER_API_KEY=YOUR_OPENROUTER_API_KEY

# Optional: override the default model (must be a valid OpenRouter model id).
RESEARCH_OS_DEFAULT_MODEL=openai/gpt-5.2

# Optional: enables the web_search tool used for the "research before assuming"
# principle. Get a key at https://tavily.com. If unset, Research-OS will still
# work but will honestly disclose that it could not verify time-sensitive claims.
TAVILY_API_KEY=YOUR_TAVILY_API_KEY

# Optional: shown to OpenRouter for its public leaderboards, not required.
RESEARCH_OS_SITE_URL=https://local.research-os
RESEARCH_OS_SITE_TITLE=Research-OS

# Optional: where Task Learning Records are stored (defaults to ~/.research_os).
RESEARCH_OS_HOME=~/.research_os
